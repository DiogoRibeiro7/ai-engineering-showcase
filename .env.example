AI_SHOWCASE_DATA_PATH=data/sample_feedback.csv
AI_SHOWCASE_INDEX_PATH=.artifacts/vector_store.json
AI_SHOWCASE_EMBEDDING_DIM=512
# LLM provider: local (default, no API key), openai, anthropic, or ollama.
AI_SHOWCASE_LLM_PROVIDER=local
# OpenAI-compatible provider (AI_SHOWCASE_LLM_PROVIDER=openai).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com
# Anthropic provider (AI_SHOWCASE_LLM_PROVIDER=anthropic, requires the 'anthropic' extra).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
# Ollama provider (AI_SHOWCASE_LLM_PROVIDER=ollama, local server, no API key).
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
AI_SHOWCASE_CONVERSATION_STORE_PATH=.artifacts/conversations
# Comma-separated browser origins allowed to call the API (CORS).
# Use "*" to allow any origin for local demos, or leave empty to disable CORS.
AI_SHOWCASE_CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:4173,http://127.0.0.1:5173,http://127.0.0.1:4173
